# Example custom sandbox image.
# Build:  docker build -t my-sandbox:latest -f images/Dockerfile.example .
# Then set SANDBOX_IMAGE=my-sandbox:latest in .env
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq ripgrep build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir numpy pandas requests httpx

WORKDIR /workspace
CMD ["bash"]
