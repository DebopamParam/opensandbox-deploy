# ── OpenSandbox Deploy Config ──

# Server
SANDBOX_API_KEY=change-me-to-something-secret
SANDBOX_PORT=8080
SANDBOX_LOG_LEVEL=INFO

# Image to use when creating sandboxes.
#   Local build:   my-sandbox:latest
#   Docker Hub:    python:3.13-slim
#   GHCR:          ghcr.io/agent-infra/sandbox:latest
SANDBOX_IMAGE=python:3.13-slim

# Resource limits per sandbox
SANDBOX_CPU=1
SANDBOX_MEMORY=512Mi
SANDBOX_TIMEOUT=1800

# GCP-only: gVisor platform (systrap for VPS, kvm for bare-metal)
GVISOR_PLATFORM=systrap
